# '.env.local' olarak kaydet ve alttakileri doldur calismasi icin:
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ─── E-posta (iletişim formu için) ───────────────────────────────────────────
# Gmail örneği:
#   1. Google Hesabım → Güvenlik → 2FA açık
#   2. Google Hesabım → Güvenlik → Uygulama şifreleri → Yeni şifre oluştur
#   3. Oluşan 16 haneli şifreyi SMTP_PASS'a yapıştır

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=openuni@gmail.com       # Gmail adresin
SMTP_PASS=xxxx xxxx xxxx xxxx    # Uygulama şifresi (boşluklu olabilir)
CONTACT_EMAIL=openuni@gmail.com  # Formun gideceği adres (SMTP_USER ile aynı olabilir)

# ─── Kurulum ─────────────────────────────────────────────────────────────────
# npm install nodemailer
# npm install --save-dev @types/nodemailer

# firebase authentication kisminda editleyerek firebase ait olmayan size ait olan email dogrulamasi kullanabilirsiniz
NEXT_PUBLIC_APP_URL=YOUR_DOMAIN

NEXT_PUBLIC_ADMIN_EMAIL=
