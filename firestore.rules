rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedStudent() {
      return isSignedIn() &&
        request.auth.token.email.matches('.*@ogr\\.gelisim\\.edu\\.tr');
    }

    function isModerator() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['moderator', 'admin'];
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
    }

    // ─── Spaces ─────────────────────────────────────────────────────────────
    match /spaces/{spaceId} {
      allow read: if isVerifiedStudent();
      allow write: if isModerator();
    }

    // ─── Posts ──────────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isVerifiedStudent();
      allow create: if isVerifiedStudent() &&
        request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.authorId == request.auth.uid ||
        isModerator()
      );
      allow delete: if isModerator();
    }

    // ─── Notifications ───────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if isModerator();
    }

  }
}
