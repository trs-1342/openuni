rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    function isStudentEmail() {
      return isSignedIn() &&
        request.auth.token.email.matches('.*@(ogr\\.)?gelisim\\.edu\\.tr');
    }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function getUserRole() {
      return getUserData().role;
    }
    function isModerator() {
      return isSignedIn() && getUserRole() in ['moderator', 'admin'];
    }
    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }
    // Okuma izni: onaylı kullanıcılar
    function isApprovedUser() {
      return isSignedIn() && (
        isStudentEmail() ||
        isModerator() ||
        getUserData().isAdminVerified == true
      );
    }
    // Yazma izni: email doğrulanmış VEYA admin/mod VEYA admin-onaylı
    function canWrite() {
      return isSignedIn() && (
        isVerified() ||
        isModerator() ||
        getUserData().isAdminVerified == true
      );
    }

    // ─── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow update: if isModerator();
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // ─── Spaces ───────────────────────────────────────────────────────────────
    match /spaces/{spaceId} {
      allow read: if isApprovedUser();
      allow create: if isModerator();
      allow update: if isModerator();
      allow delete: if isAdmin();
    }

    // ─── Posts ────────────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isApprovedUser();

      // Yeni post oluşturma
      allow create: if canWrite() && isApprovedUser() &&
        request.resource.data.authorId == request.auth.uid;

      // viewCount, viewedBy, commentCount, reactions — onaylı herkes güncelleyebilir
      // Bu alanlar: görüntüleme sayısı, yorum sayısı ve emoji tepkileri için gerekli
      allow update: if isApprovedUser() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['viewCount', 'viewedBy', 'commentCount', 'reactions']);

      // İçerik düzenleme — yazar veya moderatör
      allow update: if canWrite() && (
        resource.data.authorId == request.auth.uid || isModerator()
      );

      // Silme — moderatör veya yazarın kendisi
      allow delete: if isModerator() || (canWrite() && resource.data.authorId == request.auth.uid);
    }

    // ─── Comments ─────────────────────────────────────────────────────────────
    match /comments/{commentId} {
      allow read: if isApprovedUser();

      allow create: if canWrite() && isApprovedUser() &&
        request.resource.data.authorId == request.auth.uid;

      // Reactions — onaylı herkes güncelleyebilir
      allow update: if isApprovedUser() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reactions']);

      // İçerik düzenleme — yazar veya moderatör
      allow update: if canWrite() && (
        resource.data.authorId == request.auth.uid || isModerator()
      );

      allow delete: if isModerator() || (canWrite() && resource.data.authorId == request.auth.uid);
    }

    // ─── Notifications ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read, update: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ─── Teacher Approvals ──────────────────────────────────────────────────
    match /teacherApprovals/{docId} {
      allow read: if isModerator();
      allow create: if isSignedIn() && request.auth.uid == docId;
      allow update: if isModerator();
      allow delete: if isModerator() || (isSignedIn() && request.auth.uid == docId);
    }
  }
}
